---
import Layout from "../layouts/Layout.astro";
import { projectsPageContent } from "../config";
import ProjectCard from "../components/ProjectCard.astro";

const featured = projectsPageContent.projects.filter(p => p.featured);
const publications = projectsPageContent.projects.filter(p => p.isPublication);
const other = projectsPageContent.projects.filter(p => !p.featured && !p.isPublication);
const total = projectsPageContent.projects.length;
---

<Layout seo={projectsPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal">
    <h1 class="font-bold text-3xl mb-10 text-center">Projects</h1>

    <nav class="flex items-center gap-10 mb-12 border-b border-gray-200 dark:border-gray-800 pb-4" style="font-family:'Space Mono',monospace; font-size:14px;">
      <span class="border-b-2 border-black dark:border-white pb-4 -mb-4 text-black dark:text-white" style="cursor:default;">All Projects ({String(total).padStart(2,'0')})</span>
      <span class="opacity-40 cursor-default">Data Visualization</span>
      <span class="opacity-40 cursor-default">Art Direction</span>
    </nav>

    <div class="mb-2">
      <div class="grid grid-cols-1 group">
        {featured.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>

    <!-- Other Projects -->
    {other.length > 0 && (
      <div class="mb-2 mt-10">
        <h2 class="text-xs uppercase tracking-widest opacity-40 mb-6">More Projects</h2>
        <div class="grid grid-cols-1 group">
          {other.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    )}

    <div class="mt-10 mb-20">
      <div class="grid grid-cols-1 group">
        {publications.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>

  </section>
</Layout>
