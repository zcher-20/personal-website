---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { aboutPageContent } from "../config";
import SocialLinkBox from "../components/SocialLinkBox.astro";
import {marked} from "marked"

const pageDescription = marked.parse(aboutPageContent.about.description)
const connectDescription = marked.parse(aboutPageContent.connect.description)
---

<Layout seo={aboutPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal">
    <h1 class="font-bold text-3xl mb-1">About</h1>
    <p class="opacity-60 mb-10">{aboutPageContent.subtitle}</p>
    <div class="mb-14">
      <Fragment set:html={pageDescription} />
    </div>
    <div class="flex flex-col min-[410px]:flex-row">
      {aboutPageContent.about.image_l.link ? (
        <a href={aboutPageContent.about.image_l.link} target="_blank" rel="noopener noreferrer" class="hover:scale-105 transition-transform">
          <Image
            src={aboutPageContent.about.image_l.url}
            alt={aboutPageContent.about.image_l.alt}
            width={350}
            height={250}
            class="w-[350px] h-[250px] object-cover rounded-xl -rotate-6"
          />
        </a>
      ) : (
        <Image
          src={aboutPageContent.about.image_l.url}
          alt={aboutPageContent.about.image_l.alt}
          width={350}
          height={250}
          class="w-[350px] h-[250px] object-cover rounded-xl -rotate-6"
        />
      )}
      {aboutPageContent.about.image_r.link ? (
        <a href={aboutPageContent.about.image_r.link} target="_blank" rel="noopener noreferrer" class="hover:scale-105 transition-transform mx-auto sm:ml-auto">
          <Image
            src={aboutPageContent.about.image_r.url}
            alt={aboutPageContent.about.image_r.alt}
            width={150}
            height={250}
            class="w-[150px] h-[250px] object-cover rounded-xl rotate-6"
          />
        </a>
      ) : (
        <Image
          src={aboutPageContent.about.image_r.url}
          alt={aboutPageContent.about.image_r.alt}
          width={150}
          height={250}
          class="w-[150px] h-[250px] object-cover rounded-xl rotate-6 mx-auto sm:ml-auto"
        />
      )}
    </div>
  </section>
  {aboutPageContent.currentWork && (
    <section class="mt-32 max-w-2xl mx-auto px-6 sm:flex sm:gap-16 scroll-reveal">
      <h2 class="mb-8 sm:mb-0 opacity-60 shrink-0">Currently<br class="hidden sm:block" /> Working On</h2>
      <a
        href={aboutPageContent.currentWork.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group block flex-1 min-w-0 rounded-xl border border-neutral-200 dark:border-neutral-800 overflow-hidden hover:border-neutral-400 dark:hover:border-neutral-600 transition-colors"
      >
        <Image
          src={aboutPageContent.currentWork.image}
          alt={aboutPageContent.currentWork.title}
          width={600}
          height={300}
          class="w-full h-48 object-cover"
        />
        <div class="p-5">
          <h3 class="font-semibold text-lg mb-1">{aboutPageContent.currentWork.title}</h3>
          <p class="opacity-60 text-sm mb-3">{aboutPageContent.currentWork.description}</p>
          <span class="text-sm font-medium group-hover:underline">
            {aboutPageContent.currentWork.linkLabel} →
          </span>
        </div>
      </a>
    </section>
  )}
  <section class="mt-32 max-w-2xl mx-auto px-6 sm:flex sm:gap-16 scroll-reveal">
    <h2 class="mb-8 sm:mb-0 opacity-60">Connect</h2>
    <div>
      <div class="mb-6">
        <Fragment set:html={connectDescription} />
      </div>
      <div class="grid grid-cols-2 gap-2 group">
        {
          aboutPageContent.connect.links.map((item) => (
            <SocialLinkBox {...item} />
          ))
        }
      </div>
    </div>
  </section>
</Layout>
