---
interface Props {
  text: string;
  class?: string;
}

const { text, class: className } = Astro.props;
const chars = text.split('');
const stagger = 0.05;
---

<span class:list={["letter-3d-name", className]}>
  {chars.map((char, i) => (
    char === ' ' ? (
      <span>&nbsp;</span>
    ) : (
      <span class="letter-3d-box">
        <span class="letter-3d-flip" style={`--d: ${(i * stagger).toFixed(2)}s`}>
          <span class="letter-3d-front">{char}</span>
          <span class="letter-3d-back" aria-hidden="true">{char}</span>
        </span>
      </span>
    )
  ))}
</span>

<style>
  .letter-3d-name {
    display: inline;
    cursor: default;
  }

  .letter-3d-box {
    display: inline-block;
    perspective: 600px;
  }

  .letter-3d-flip {
    display: inline-block;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.25, 1.15, 0.35, 1) var(--d, 0s);
  }

  .letter-3d-front,
  .letter-3d-back {
    display: inline-block;
    backface-visibility: hidden;
  }

  .letter-3d-back {
    position: absolute;
    top: 0;
    left: 0;
    transform: rotateX(-180deg);
  }

  @media (hover: hover) {
    .letter-3d-name:hover .letter-3d-flip {
      transform: rotateX(-180deg);
    }
  }
</style>
