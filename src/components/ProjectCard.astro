---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import {marked} from "marked"

type Props = Project;

const { title, description, image, year, url, demoUrl, pdfUrl, tags, venue, skills, learnings, focus, links: projectLinks, linkLabel: customLinkLabel } = Astro.props;
const htmlDescription = marked.parse(description);
const cardId = Math.random().toString(36).slice(2, 8);
const displaySkills = skills || tags || [];
const linkLabel = customLinkLabel || (pdfUrl || url.includes('openreview') || url.includes('ijcai') ? 'Read paper' : 'GitHub');
---

<div class="py-6 sm:py-8 flex flex-col sm:flex-row gap-5 sm:gap-8 group-hover:opacity-60 hover:!opacity-100 transition-opacity project-card-wrap" style="position:relative;">
  <div class="w-full sm:w-[38%] flex-shrink-0">
    <div class="rounded-lg overflow-hidden border border-neutral-200 dark:border-neutral-800" style="background:#f5f5f7;">
      <div
        id={`panel-img-${cardId}`}
        class="aspect-video sm:aspect-[4/3] cursor-zoom-in"
      >
        {pdfUrl ? (
          <div class="w-full h-full flex items-center justify-center" style="background:#fafafa;">
            <div class="text-center" style="opacity:0.35;">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <p style="font-size:10px; margin-top:4px;">PDF</p>
            </div>
          </div>
        ) : (
          <Image
            width={1920}
            height={1080}
            src={image}
            alt={title}
            class="w-full h-full object-cover"
          />
        )}
      </div>
      <div
        id={`panel-info-${cardId}`}
        class="aspect-video sm:aspect-[4/3] p-4 flex flex-col justify-center"
        style="display:none;"
      >
        {learnings && (
          <p style="font-size:12px; color:#333; margin:0 0 12px; line-height:1.5;" class="dark:text-neutral-300">{learnings}</p>
        )}
        {focus && focus.length > 0 && (
          <div style="margin-bottom:12px;">
            <p style="font-size:11px; margin:0 0 6px; font-weight:700;" class="opacity-70">Focus</p>
            <ul style="margin:0; padding:0; list-style:none;">
              {focus.map((f) => (
                <li style="font-size:11px; padding:2px 0;" class="opacity-60">&ndash; {f}</li>
              ))}
            </ul>
          </div>
        )}
        <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:auto;">
          {url === "#" ? (
            <span class="hovercard-link-primary" style="cursor:default; opacity:0.6;">{linkLabel}</span>
          ) : (
            <a
              href={url}
              target="_blank"
              class="hovercard-link-primary"
            >{linkLabel} &rarr;</a>
          )}
          {demoUrl && (
            <a
              href={demoUrl}
              target="_blank"
              class="hovercard-link-secondary"
            >Demo &rarr;</a>
          )}
        </div>
      </div>
    </div>
    <div class="flex justify-center mt-2">
      <button
        id={`flip-${cardId}`}
        class="project-flip-btn"
        aria-label="Flip card"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      </button>
    </div>
  </div>

  <div class="flex-1 flex flex-col justify-center min-w-0">
    <div class="flex items-baseline gap-2 mb-1">
      <span
        class="font-semibold"
        style="font-size:15px;"
      >{title}</span>
      {year && <span style="font-size:12px; opacity:0.4;">{year}</span>}
    </div>

    {venue && (
      <p style="font-size:11px; opacity:0.45; margin:0 0 8px; letter-spacing:0.01em;">{venue}</p>
    )}

    <div style="font-size:13px; opacity:0.55; line-height:1.6; margin-bottom:12px;">
      <Fragment set:html={htmlDescription} />
    </div>

    {displaySkills.length > 0 && (
      <div style="display:flex; flex-wrap:wrap; gap:6px;">
        {displaySkills.map((s) => (
          <span class="skill-box">{s}</span>
        ))}
      </div>
    )}
  </div>
</div>

<!-- Lightbox (moved to body via JS to escape scroll-reveal transforms) -->
<template id={`lightbox-tpl-${cardId}`}>
  <div
    id={`lightbox-${cardId}`}
    class="project-lightbox"
  >
    <button
      id={`close-${cardId}`}
      class="project-lightbox-close"
    >&times;</button>

    {pdfUrl ? (
      <div
        id={`card-${cardId}`}
        class="project-lightbox-content"
        onclick="event.stopPropagation()"
      >
        <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
          <div style="flex:1; overflow:hidden; display:flex; align-items:center; justify-content:center; background:#f5f5f5; padding:16px; min-height:400px;">
            <canvas id={`pdf-canvas-${cardId}`} style="max-width:100%; max-height:100%; object-fit:contain; box-shadow:0 4px 20px rgba(0,0,0,0.15);"></canvas>
          </div>
          <div style="height:56px; display:flex; align-items:center; justify-content:center; gap:24px; border-top:1px solid #eee; flex-shrink:0; background:#fff;">
            <button id={`prev-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">&larr;</button>
            <span id={`page-info-${cardId}`} style="font-size:13px; opacity:0.5; min-width:60px; text-align:center;">1 / ?</span>
            <button id={`next-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">&rarr;</button>
          </div>
        </div>
      </div>
    ) : (
      <div style="display:flex; align-items:center; justify-content:center; padding:32px; cursor:default; max-width:90vw; max-height:90vh;" onclick="event.stopPropagation()">
        <img src={image} alt={title} style="max-width:100%; max-height:80vh; object-fit:contain; border-radius:8px;" />
      </div>
    )}
  </div>
</template>

<style>
  .skill-box {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 3px;
    background: transparent;
    color: #6b7280;
    font-family: inherit;
    line-height: 1.4;
  }

  .project-flip-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.4;
    transition: opacity 0.15s, transform 0.3s;
    color: inherit;
  }

  .project-flip-btn:hover {
    opacity: 0.8;
    transform: rotate(180deg);
  }

  :global(.dark) .project-flip-btn {
    background: #1a1a1a;
    border-color: rgba(255, 255, 255, 0.12);
  }

  .hovercard-link-primary {
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid #222;
    color: #222;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hovercard-link-secondary {
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid #d1d5db;
    color: #6b7280;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.project-lightbox) {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    animation: lightbox-fade-in 0.2s ease-out;
  }

  @keyframes lightbox-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  :global(.project-lightbox-close) {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 10001;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  :global(.project-lightbox-content) {
    position: relative;
    width: min(90vw, 920px);
    max-height: 85vh;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    cursor: default;
  }
</style>

<script define:vars={{ cardId, pdfUrl }}>
  const flipBtn   = document.getElementById('flip-' + cardId);
  const panelImg  = document.getElementById('panel-img-' + cardId);
  const panelInfo = document.getElementById('panel-info-' + cardId);
  let showingInfo = false;

  flipBtn?.addEventListener('click', () => {
    showingInfo = !showingInfo;
    panelImg.style.display = showingInfo ? 'none' : '';
    panelInfo.style.display = showingInfo ? '' : 'none';
  });

  // Move lightbox out of scroll-reveal to document.body so position:fixed works
  const tpl = document.getElementById('lightbox-tpl-' + cardId);
  if (tpl) {
    const content = tpl.content.cloneNode(true);
    document.body.appendChild(content);
    tpl.remove();
  }

  const lightbox    = document.getElementById('lightbox-' + cardId);
  const closeBtn    = document.getElementById('close-' + cardId);

  // Lightbox logic
  function openLightbox() {
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    if (pdfUrl) initPdf();
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  panelImg?.addEventListener('click', openLightbox);
  lightbox?.addEventListener('click', closeLightbox);
  closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox?.style.display === 'flex') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight' && pdfUrl) nextPage();
      if (e.key === 'ArrowLeft' && pdfUrl) prevPage();
    }
  });

  let pdfDoc = null;
  let currentPage = 1;
  let rendering = false;
  let pdfInitialized = false;

  async function initPdf() {
    if (pdfInitialized) return;
    pdfInitialized = true;
    await new Promise((resolve) => {
      if (window.pdfjsLib) { resolve(); return; }
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      script.onload = () => resolve();
      document.head.appendChild(script);
    });
    const pdfjsLib = window.pdfjsLib;
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    pdfDoc = await pdfjsLib.getDocument(pdfUrl).promise;
    updatePageInfo();
    renderPage(1);
  }

  function updatePageInfo() {
    const info = document.getElementById('page-info-' + cardId);
    if (info && pdfDoc) info.textContent = currentPage + ' / ' + pdfDoc.numPages;
  }

  async function renderPage(num) {
    if (!pdfDoc || rendering) return;
    rendering = true;
    const page = await pdfDoc.getPage(num);
    const canvas = document.getElementById('pdf-canvas-' + cardId);
    const container = canvas.parentElement;
    const scale = Math.min(
      (container.clientWidth - 32) / page.getViewport({ scale: 1 }).width,
      (container.clientHeight - 32) / page.getViewport({ scale: 1 }).height
    );
    const viewport = page.getViewport({ scale });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    rendering = false;
    updatePageInfo();
  }

  function nextPage() {
    if (pdfDoc && currentPage < pdfDoc.numPages) { currentPage++; renderPage(currentPage); }
  }

  function prevPage() {
    if (pdfDoc && currentPage > 1) { currentPage--; renderPage(currentPage); }
  }

  document.getElementById('next-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); nextPage(); });
  document.getElementById('prev-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); prevPage(); });
</script>
